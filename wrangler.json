{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "flytripvisaweb",
	"main": "./workers/app.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"vars": {
		"VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare (FlyTripVisa)"
	}
}
"ai": { "binding": "AI" }
{
  "analytics_engine_datasets": [
    { "binding": "FlyTripVisa_DB", "dataset": "FlyTripVisa_DB" }
  ]
}
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flytripvisa-assistant",
  "main": "src/index.js",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "CF_ACCOUNT_ID": "b73b80fa62deef032d3c08248cf2f30b"
  },
  "ai": {
    "binding": "AI"
  },
  "services": [
    {
      "binding": "AI_GATEWAY",
      "service": "default"
    }
  ]
}
